# ─────────────────────────────────────────────────────────────
# PPT Agent Service Configuration / PPT Agent 服务配置
# ─────────────────────────────────────────────────────────────
# 
# This file contains configuration for the Agent Service.
# Copy this file to .env and fill in your values.
# 复制此文件为 .env 并填写你的配置值。
#
# IMPORTANT:
# - Never commit .env to version control (it's in .gitignore)
# - 不要将 .env 提交到版本控制（已在 .gitignore 中）
# - All values are optional with sensible defaults
# - 所有值都是可选的，有合理的默认值

# ─────────────────────────────────────────────────────────────
# LLM Configuration / 大语言模型配置（必需）
# ─────────────────────────────────────────────────────────────

# OpenAI-compatible API endpoint / OpenAI兼容API端点
OPENAI_BASE_URL=https://api.openai.com/v1

# API Key for LLM service / LLM服务的API密钥
OPENAI_API_KEY=sk-your-api-key-here

# Model name to use / 使用的模型名称
# Options: gpt-4o, gpt-4o-mini, gpt-3.5-turbo, or any compatible model
# 选项：gpt-4o, gpt-4o-mini, gpt-3.5-turbo, 或任何兼容模型
OPENAI_MODEL=gpt-4o

# Alternative providers example / 其他提供商示例：
# DeepSeek: OPENAI_BASE_URL=https://api.deepseek.com/v1 OPENAI_MODEL=deepseek-chat
# Qwen (DashScope): OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1 OPENAI_MODEL=qwen-plus
# Zhipu (GLM): OPENAI_BASE_URL=https://open.bigmodel.cn/api/paas/v4 OPENAI_MODEL=glm-4
# Local Ollama: OPENAI_BASE_URL=http://localhost:11434/v1 OPENAI_MODEL=llama3

# ─────────────────────────────────────────────────────────────
# Server Configuration / 服务器配置
# ─────────────────────────────────────────────────────────────

# Host to bind to / 绑定的主机地址 (default: 0.0.0.0 for all interfaces)
HOST=0.0.0.0

# Port to listen on / 监听端口 (default: 8000)
PORT=8000

# ─────────────────────────────────────────────────────────────
# Logging Configuration / 日志配置
# ─────────────────────────────────────────────────────────────

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
# 日志级别：DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ─────────────────────────────────────────────────────────────
# Performance Tuning / 性能调优
# ─────────────────────────────────────────────────────────────

# LLM request timeout in seconds / LLM请求超时时间（秒）
LLM_TIMEOUT=120

# Maximum retries for LLM calls / LLM调用最大重试次数
LLM_MAX_RETRIES=2

# Script execution timeout in seconds / 脚本执行超时时间（秒）
SCRIPT_TIMEOUT=600

# ─────────────────────────────────────────────────────────────
# Image Generation Configuration / 图片生成配置（可选）
# ─────────────────────────────────────────────────────────────
# See ../.env.example for full image generation options
# 查看上层目录的 .env.example 获取完整的图片生成选项

# IMAGE_BACKEND=openai
# OPENAI_API_KEY=sk-your-image-key (if different from LLM key)

# ─────────────────────────────────────────────────────────────
# Security Settings / 安全设置（可选）
# ─────────────────────────────────────────────────────────────

# CORS origins (comma-separated) / CORS来源（逗号分隔）
# Default: * (allow all) / 默认：*（允许所有）
CORS_ORIGINS=*

# API rate limiting (requests per minute) / API速率限制（每分钟请求数）
# Set to 0 to disable / 设为0禁用
RATE_LIMIT=0
